rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function to check if the user is a staff member
    function isStaff() {
      return isAuth() && request.auth.token.staff == true;
    }

    // Default-deny catch-all to secure all collections by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Settings collection (layout configuration like 'beds' and 'rows')
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Config collection (priceList, subscriptionSetup)
    match /config/{configId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Tabs collection
    match /tabs/{tabId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Subscriptions collection
    match /subscriptions/{subscriptionId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Customers collection
    match /customers/{customerId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Ledger collection
    match /ledger/{ledgerId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Attendance collection
    match /attendance/{attendanceId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Pricing collection
    match /pricing/{pricingId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // DailyPresences collection
    match /dailyPresences/{presenceId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // SourceDocuments collection
    match /sourceDocuments/{docId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // AssistantSessions collection and messages subcollection
    match /assistantSessions/{sessionId} {
      allow read, write: if isAuth();
      
      match /messages/{messageId} {
        allow read, write: if isAuth();
      }
    }
  }
}
